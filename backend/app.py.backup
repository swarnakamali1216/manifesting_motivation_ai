import os
from flask import Flask, jsonify
from flask_cors import CORS
from dotenv import load_dotenv

load_dotenv()

app = Flask(__name__)

# Allow localhost:3000 and production frontend URL
_origins = [
    "http://localhost:3000",
    "http://127.0.0.1:3000",
    "http://localhost:3001",
]
_extra = os.environ.get("FRONTEND_URL", "")
if _extra:
    _origins.append(_extra)

# âœ… FIXED: Add X-CSRF-Token to allowed headers
CORS(app,
     origins=_origins,
     supports_credentials=True,
     allow_headers=["Content-Type", "Authorization", "X-Requested-With", "X-CSRF-Token"],
     methods=["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"])

# â”€â”€ Blueprints â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
from routes.auth import auth_bp
from routes.motivation      import motivation_bp
from routes.history         import history_bp
from routes.goals           import goals_bp
from routes.journal         import journal_bp
from routes.checkin         import checkin_bp
from routes.gamification    import gamification_bp
from routes.admin           import admin_bp
from routes.invite          import invite_bp
from routes.elevenlabs      import elevenlabs_bp
from routes.db_health       import db_health_bp
from routes.privacy         import privacy_bp

def safe_import(module, name):
    try:
        import importlib
        m = importlib.import_module(module)
        return getattr(m, name)
    except Exception as e:
        print(f"âš ï¸  Optional blueprint {name} not loaded: {e}")
        return None

google_auth_bp = safe_import("routes.google_auth", "google_auth_bp")

realtime_bp    = safe_import("routes.realtime",            "realtime_bp")
memory_bp      = safe_import("routes.memory",              "memory_bp")
predictor_bp   = safe_import("routes.predictor",           "predictor_bp")
adaptive_bp    = safe_import("routes.adaptive_goals",      "adaptive_bp")
rag_bp         = safe_import("routes.rag_resources",       "rag_bp")
recursive_bp   = safe_import("routes.recursive_roadmap",   "recursive_bp")

def safe_import_multi(module, *names):
    try:
        import importlib
        m = importlib.import_module(module)
        for name in names:
            if hasattr(m, name):
                return getattr(m, name)
        return None
    except Exception:
        return None

spaced_bp = safe_import_multi("routes.spaced_repetition",
                    "spaced_repetition_bp", "spaced_review_bp",
                    "spaced_bp", "review_bp")
weekly_bp = safe_import_multi("routes.weekly_report",
                    "weekly_report_bp", "weekly_bp", "report_bp")

# Register blueprints
for bp in [auth_bp, motivation_bp, history_bp, goals_bp, journal_bp,
           checkin_bp, gamification_bp, admin_bp, invite_bp,
           elevenlabs_bp, db_health_bp, privacy_bp]:
    app.register_blueprint(bp, url_prefix="/api")

for bp in [google_auth_bp, realtime_bp, memory_bp, predictor_bp, adaptive_bp,
           spaced_bp, rag_bp, recursive_bp, weekly_bp]:
    if bp is not None:
        app.register_blueprint(bp, url_prefix="/api")

# â”€â”€ Health + route list â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
@app.route("/api/health")
def health():
    return jsonify({
        "status":      "ok",
        "groq":        bool(os.environ.get("GROQ_API_KEY")),
        "elevenlabs":  bool(os.environ.get("ELEVENLABS_API_KEY")),
        "db":          bool(os.environ.get("DATABASE_URL")),
    })

@app.route("/api/routes")
def list_routes():
    routes = []
    for rule in app.url_map.iter_rules():
        routes.append({"path": str(rule), "methods": sorted(rule.methods - {"HEAD","OPTIONS"})})
    return jsonify(sorted(routes, key=lambda r: r["path"]))

